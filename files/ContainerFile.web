FROM docker.io/library/tomcat:9.0.102-jdk11

MAINTAINER "chachacreate<kirk0221@naver.com>"

# 기본 웹앱 제거(혹시나 이전에 남아있는 Application을 삭제하기 위해)
RUN rm -rf /usr/local/tomcat/webapps/*

# envsubst 설치 (env를 사용하여 template에 적용하기 위해, gettext 패키지에 포함)
RUN apt-get update && \
    apt-get upgrade -y && \
    apt-get install -y --no-install-recommends \
        gettext-base \
    && rm -rf /var/lib/apt/lists/*

# 환경변수 설정
ENV TZ=Asia/Seoul

# 시간대 설정
RUN ln -snf /usr/share/zoneinfo/Asia/Seoul /etc/localtime && echo Asia/Seoul > /etc/timezone

# WAR 파일을 ROOT 디렉토리로 직접 압축 해제
ADD target/ROOT.war /tmp/ROOT.war
RUN cd /usr/local/tomcat/webapps && \
    mkdir ROOT && \
    cd ROOT && \
    jar -xf /tmp/ROOT.war && \
    rm /tmp/ROOT.war

# WAR 파일에서 Oracle 라이브러리 추출 (Tomcat 서버에서 Oracle wallet에 접속하기 위해 ojdbc를 가져오고 ssl연결을 위해 oralcepki, osdt를 가져옴)
RUN cp /usr/local/tomcat/webapps/ROOT/WEB-INF/lib/ojdbc*.jar /usr/local/tomcat/lib/ 2>/dev/null || true && \
    cp /usr/local/tomcat/webapps/ROOT/WEB-INF/lib/oraclepki*.jar /usr/local/tomcat/lib/ 2>/dev/null || true && \
    cp /usr/local/tomcat/webapps/ROOT/WEB-INF/lib/osdt*.jar /usr/local/tomcat/lib/ 2>/dev/null || true

# 버전 번호 없는 심볼릭 링크 생성 (Tomcat 서버에서 버전 없는 파일명을 찾기 때문에)
RUN cd /usr/local/tomcat/lib/ && \
    for f in ojdbc*.jar; do [ -f "$f" ] && ln -sf "$f" ojdbc11.jar; done && \
    for f in oraclepki*.jar; do [ -f "$f" ] && ln -sf "$f" oraclepki.jar; done && \
    for f in osdt_cert*.jar; do [ -f "$f" ] && ln -sf "$f" osdt_cert.jar; done && \
    for f in osdt_core*.jar; do [ -f "$f" ] && ln -sf "$f" osdt_core.jar; done

# oracle.osdt 디렉토리도 생성 (Tomcat 서버에서 찾는 위치랑 맞춰주기 위해)
RUN mkdir -p /usr/local/tomcat/oracle.osdt && \
    cd /usr/local/tomcat/oracle.osdt && \
    for f in /usr/local/tomcat/lib/osdt_core*.jar; do [ -f "$f" ] && ln -sf "$f" osdt_core.jar; done && \
    for f in /usr/local/tomcat/lib/osdt_cert*.jar; do [ -f "$f" ] && ln -sf "$f" osdt_cert.jar; done

# Context template 복사 (디렉토리 먼저 생성 후 복사)
RUN mkdir -p /usr/local/tomcat/conf/Catalina/localhost
ADD files/ROOT.xml.template /usr/local/tomcat/conf/Catalina/localhost/ROOT.xml.template

# Tomcat 서버 설정 복사
ADD files/server.xml /usr/local/tomcat/conf/server.xml

# 시작 스크립트 (환경변수 기반으로 ROOT.xml.template을 사용하여 Context 생성)
RUN echo '#!/bin/bash' > /usr/local/tomcat/bin/start.sh && \
    echo 'envsubst < /usr/local/tomcat/conf/Catalina/localhost/ROOT.xml.template > /usr/local/tomcat/conf/Catalina/localhost/ROOT.xml' >> /usr/local/tomcat/bin/start.sh && \
    echo 'exec /usr/local/tomcat/bin/catalina.sh run' >> /usr/local/tomcat/bin/start.sh && \
    chmod +x /usr/local/tomcat/bin/start.sh

EXPOSE 8080

CMD ["/usr/local/tomcat/bin/start.sh"]